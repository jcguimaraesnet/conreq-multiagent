# ===== BUILD =====
FROM node:20-bullseye AS builder

WORKDIR /app

# Instala pnpm
RUN npm install -g pnpm

# Copia apenas arquivos de dependência primeiro (cache)
COPY package.json pnpm-lock.yaml ./
COPY patches ./patches
RUN pnpm install

# Copia o restante do frontend
COPY . .

# ===== ENV VARS (BUILD TIME) =====
ARG NEXT_PUBLIC_SUPABASE_URL
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY
ARG NEXT_PUBLIC_SITE_URL
ARG NEXT_PUBLIC_API_URL
ARG LANGGRAPH_DEPLOYMENT_URL
ARG LANGSMITH_API_KEY

ENV NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL
ENV NEXT_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY
ENV NEXT_PUBLIC_SITE_URL=$NEXT_PUBLIC_SITE_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV LANGGRAPH_DEPLOYMENT_URL=$LANGGRAPH_DEPLOYMENT_URL
ENV LANGSMITH_API_KEY=$LANGSMITH_API_KEY

# Build do Next.js
RUN pnpm build:turbopack

# ===== RUN =====
FROM node:20-bullseye

WORKDIR /app

# Variáveis obrigatórias para o standalone funcionar corretamente no Docker
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# 1. Copia a pasta public (imagens, ícones, etc)
COPY --from=builder /app/public ./public

# 2. Copia a pasta standalone gerada pelo Next.js (contém o server.js e dependências mínimas)
COPY --from=builder /app/.next/standalone ./

# 3. Copia a pasta static gerada pelo Next.js (arquivos JS/CSS do cliente que o standalone não inclui na raiz)
COPY --from=builder /app/.next/static ./.next/static

EXPOSE 3000

# Executa o servidor Node otimizado diretamente (sem pnpm ou npm)
CMD ["node", "server.js"]